# ============================================
# Agenda AI Personal - Variables de Entorno
# ============================================
# Copia este archivo a .env.local y completa los valores

# URL de la aplicación (para SEO y Open Graph)
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app

# Firebase Configuration
# Obtén estos valores en: https://console.firebase.google.com
# Tu proyecto > Configuración del proyecto > Tus apps > Config
NEXT_PUBLIC_FIREBASE_API_KEY=tu-api-key-aqui
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Anthropic Claude AI
# Obtén tu key en: https://console.anthropic.com
# 1. Crea una cuenta o inicia sesión
# 2. Ve a API Keys y genera una nueva key
# 3. Copia la API Key generada (empieza con sk-ant-...)
ANTHROPIC_API_KEY=sk-ant-tu-key-aqui

# Firebase Cloud Messaging - VAPID Key (Push Notifications)
# Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin Service Account (Server-Side)
# Necesario para enviar push (FCM HTTP v1) y para el cron de recordatorios.
# Firebase Console > Configuración del proyecto > Cuentas de servicio >
# "Generar nueva clave privada" → pega el JSON COMPLETO aquí (en una sola línea).
FIREBASE_SERVICE_ACCOUNT=

# Secreto compartido para proteger el endpoint /api/cron/reminders.
# Pon cualquier cadena aleatoria larga. Debe ser igual en Netlify.
CRON_SECRET=
