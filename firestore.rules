rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isDocumentOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }
    function hasValidUserId() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // ── COMPARTIDA: users ────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ── NEXOIA MOBILE ────────────────────────────────────────────────────
    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.providerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.providerId == request.auth.uid;
    }
    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.providerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.clientId == request.auth.uid || resource.data.providerId == request.auth.uid);
      allow delete: if false;
    }
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.clientId == request.auth.uid;
    }
    match /ai_conversations/{conversationId} {
      allow read: if isSignedIn() && (request.auth.uid == conversationId || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (request.auth.uid == conversationId || request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (request.auth.uid == conversationId || (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid));
      allow delete: if isSignedIn() && (request.auth.uid == conversationId || resource.data.userId == request.auth.uid);
    }

    // ── WEB APP ──────────────────────────────────────────────────────────
    match /tasks/{taskId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /events/{eventId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /projects/{projectId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /categories/{categoryId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /analytics/{analyticsId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /notifications/{notificationId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /chats/{chatId} {
      allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner();
      match /messages/{messageId} {
        allow read: if get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
        allow write: if get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
      }
    }
    match /chat_messages/{messageId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /transactions/{transactionId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /budgets/{budgetId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /debts/{debtId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /receivables/{receivableId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /user_profiles/{profileId} { allow read, create, update, delete: if isSignedIn() && request.auth.uid == profileId; }
    match /user_integrations/{userId} { allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId; }
    match /memories/{memoryId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /fcm_tokens/{tokenId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner() && hasValidUserId(); allow delete: if isDocumentOwner(); }
    match /api_tokens/{tokenId} { allow read: if isDocumentOwner(); allow create: if hasValidUserId(); allow update: if isDocumentOwner(); allow delete: if isDocumentOwner(); }

    // ── LA MELMA ─────────────────────────────────────────────────────────
    match /artists/{artistId} {
      allow read, write: if isSignedIn();
    }
    match /bookings/{bookingId} {
      allow read, write: if isSignedIn();
    }
    match /venues/{venueId} {
      allow read, write: if isSignedIn();
    }
    match /availability/{artistId}/slots/{slotId} {
      allow read, write: if isSignedIn();
    }
    match /tourRoutes/{routeId} {
      allow read, write: if isSignedIn();
    }
    match /notifications/{userId}/items/{itemId} {
      allow read, write: if isSignedIn();
    }
  }
}
